Algoritmo "pedroex1"

Var
excesso , limite , multa , peso ,taxa: real

Inicio
limite <- 50
taxa <- 4

escreval("Qual È o peso?")
leia(peso)

se (peso > limite) entao
   excesso <- peso - limite
   multa <- excesso * 4
   escreval("A multa È de R$: ",multa)
   escreval("O excesso de peso foi ",
                               excesso)
senao
     escreval("N„o h· multa :)")
fimSe




Fimalgoritmo