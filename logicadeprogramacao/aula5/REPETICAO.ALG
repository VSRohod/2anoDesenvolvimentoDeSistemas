Algoritmo "semnome"

Var
contador : real

Inicio
enquanto ( falso ) faca
   escreval("OI")
   interrompa
fimEnquanto

enquanto (contador < 10000) faca
   escreval(contador+1)
   
   se (contador = 100) entao
     escreval("Limite m·ximo!")
     interrompa
   fimSe
   
   contador <- contador + 1
fimEnquanto

escreval("OLHA A REPETI«√O")



Fimalgoritmo